<div class="pfg-chat-card">
  {{#if isFinal}}
    <h3>Entretien Hebdomadaire termine - {{actor.name}}</h3>
    <p><strong>Semaine:</strong> {{calendar.calendarLabel}}</p>
    {{#if calendar.eventName}}
      <p><strong>Evenement de la semaine:</strong> {{calendar.eventName}}</p>
    {{/if}}
    {{#if calendar.eventDescription}}
      <p>{{calendar.eventDescription}}</p>
    {{/if}}
    <p><strong>PR total:</strong> {{totalPRLabel}}</p>
    <p><strong>PR depenses:</strong> {{spentPRLabel}}</p>
    <p><strong>PR restants:</strong> {{remainingPRLabel}}</p>
    <h4>Activités</h4>
    <ol>
      {{#each activities}}
        {{#if isCrafting}}
          <li>
            {{title}} - {{summaryLine}}, coût {{costLabel}}, {{moneyCostLabel}}
            {{#if isWeaponCraft}}
              <ol>
                {{#each weapon.summaryLines}}
                  <li>{{this}}</li>
                {{/each}}
              </ol>
            {{/if}}
          </li>
        {{else}}
        {{#if isHarvest}}
          <li>
            {{title}} - {{summaryLine}}, coût {{costLabel}}
            {{#if hasResultEntries}}
              <ol>
                {{#each resultEntries}}
                  <li>{{label}}</li>
                {{/each}}
              </ol>
            {{/if}}
          </li>
        {{else}}
          <li>{{title}} - {{totalGain}}₽ gagnés, coût {{costLabel}}</li>
        {{/if}}
        {{/if}}
      {{/each}}
    </ol>
    <h4>Modifications</h4>
    <ul>
      {{#each activities}}
        {{#if isCrafting}}
          <li>Fabrication: {{resultStatus}} Argent: -{{moneyCostLabel}}</li>
        {{else}}
        {{#if isHarvest}}
          <li>Récolte: {{resultStatus}}</li>
        {{else}}
          {{#if applied}}
            <li>Argent: +{{moneyDelta}}₽ appliqué</li>
          {{else}}
            <li>Argent: +{{totalGain}}₽ non appliqué</li>
          {{/if}}
        {{/if}}
        {{/if}}
      {{/each}}
    </ul>
  {{else}}
    {{#if activity.isCrafting}}
      <h3>⚙️ Fabrication — {{actor.name}}</h3>
      <p><strong>Objet fabriqué:</strong> {{activity.itemName}} × {{activity.quantity}}</p>
      <p><strong>Type:</strong> {{activity.craftTypeLabel}}</p>
      {{#if activity.isWeaponCraft}}
        <p><strong>Base:</strong> {{activity.weapon.categoryLabel}} - {{activity.weapon.baseLabel}}</p>
        <p><strong>Moves:</strong> {{activity.weapon.moveLabels}}</p>
        <ul>
          {{#each activity.weapon.summaryLines}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      {{/if}}
      <p><strong>Coût PR:</strong> {{activity.costLabel}}</p>
      <p><strong>Coût Pokédollars:</strong> {{activity.moneyCostLabel}}</p>
      {{#if activity.hasIngredients}}
        <p><strong>Ingrédients consommés:</strong></p>
        <ul>
          {{#each activity.ingredients}}
            <li>{{name}} × {{quantity}}</li>
          {{/each}}
        </ul>
      {{/if}}
      <p><strong>Résultat:</strong> {{activity.resultStatus}}</p>
      <p><strong>PR restants:</strong> {{remainingPRLabel}}</p>
    {{else}}
    {{#if activity.isHarvest}}
      <h3>Récolte Pokémon - {{actor.name}}</h3>
      <p><strong>Récolte:</strong> {{activity.harvestLabel}} ({{activity.harvestCategory}})</p>
      <p><strong>Nombre:</strong> {{activity.count}}</p>
      <p><strong>{{#if activity.usesPokemon}}Pokémon{{else}}Prérequis{{/if}}:</strong> {{activity.pokemonNames}}</p>
      <p><strong>Cout:</strong> {{activity.costLabel}}</p>
      <p><strong>Résultat:</strong> {{activity.resultLabel}} - {{activity.resultTypeLabel}}</p>
      {{#if activity.hasResultEntries}}
        <p><strong>Résultats obtenus:</strong></p>
        <ol>
          {{#each activity.resultEntries}}
            <li>{{label}}</li>
          {{/each}}
        </ol>
      {{/if}}
      {{#if activity.resultUuid}}
        <p><strong>UUID:</strong> {{activity.resultUuid}}</p>
      {{/if}}
      <p><strong>Statut:</strong> {{activity.resultStatus}}</p>
      <p><strong>PR restants:</strong> {{remainingPRLabel}}</p>
    {{else}}
      <h3>Petit Travail Hebdomadaire - {{actor.name}}</h3>
      <p><strong>Travail:</strong> {{activity.description}}</p>
      <p><strong>Skill:</strong> {{activity.skillLabel}} - {{activity.skillRankLabel}}</p>
      {{#if activity.skillTotalDetail}}
        <p><strong>Total skill:</strong> {{activity.skillTotalDetail}}; {{activity.skillDiceFormula}}</p>
      {{/if}}
      <p><strong>Nombre de travaux:</strong> {{activity.count}}</p>
      <p><strong>Cout:</strong> {{activity.costLabel}}</p>
      <ol>
        {{#each activity.rolls}}
          <li>{{die}} x {{rate}}₽ = {{gain}}₽</li>
        {{/each}}
      </ol>
      <p><strong>Total gagné:</strong> {{activity.totalGain}}₽</p>
      <p><strong>PR restants:</strong> {{remainingPRLabel}}</p>
    {{/if}}
    {{/if}}
  {{/if}}
</div>
