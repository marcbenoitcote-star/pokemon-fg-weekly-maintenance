<form class="pfg-maintenance-form">
  <header class="pfg-maintenance-header">
    <div>
      <h2>{{title}}</h2>
      {{#if actor}}
        <p>{{actorName}} - Argent actuel: {{actorMoney}}₽</p>
      {{else}}
        <p>Entretien hebdomadaire des Trainers Pokémon FG</p>
      {{/if}}
    </div>
    <button type="button" data-action="cancel" title="Fermer">
      <i class="fas fa-xmark"></i>
    </button>
  </header>

  <nav class="pfg-maintenance-steps" aria-label="Étapes">
    {{#each steps}}
      <span class="pfg-step {{#if active}}active{{/if}} {{#if done}}done{{/if}}">
        {{label}}
      </span>
    {{/each}}
  </nav>

  {{#if actor}}
    <section class="pfg-pr-strip">
      <div>
        <span>Total PR</span>
        <strong>{{totalPRLabel}}</strong>
      </div>
      <div>
        <span>Dépensés</span>
        <strong>{{spentPRLabel}}</strong>
      </div>
      <div>
        <span>Restants</span>
        <strong>{{remainingPRLabel}}</strong>
      </div>
    </section>
  {{/if}}

  {{#if isTrainerStep}}
    <section class="pfg-calendar-banner {{#if calendar.simpleCalendarActive}}ready{{else}}missing{{/if}}">
      <div>
        <h3>Calendrier</h3>
        {{#if calendar.simpleCalendarActive}}
          <p><strong>Date actuelle:</strong> {{calendar.dateLabel}}{{#if calendar.timeLabel}} - {{calendar.timeLabel}}{{/if}}</p>
          <p class="pfg-calendar-source">Simple Calendar Reborn détecté: {{calendar.simpleCalendarStatus.moduleId}} {{calendar.simpleCalendarStatus.version}}</p>
        {{else}}
          <p><strong>Simple Calendar Reborn non détecté ou API non prête.</strong></p>
          <p class="pfg-calendar-source">Module attendu: {{calendar.simpleCalendarStatus.moduleId}}</p>
        {{/if}}
      </div>
    </section>

    <section class="pfg-panel">
      <h3>Sélection Trainer</h3>
      {{#if hasTrainers}}
        <label>
          Trainer
          <select name="actorId">
            <option value="">Choisir un Trainer</option>
            {{#each trainers}}
              <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
            {{/each}}
          </select>
        </label>
        <div class="pfg-trainer-list">
          {{#each trainers}}
            <button type="button" class="pfg-trainer-choice {{#if selected}}selected{{/if}}" data-action="choose-trainer" data-actor-id="{{id}}">
              <i class="fas fa-user"></i>
              <span>{{name}}</span>
            </button>
          {{/each}}
        </div>
      {{else}}
        <p class="pfg-warning">Aucun Actor de type character disponible pour cet utilisateur.</p>
      {{/if}}
    </section>

    <footer class="pfg-actions">
      <button type="button" data-action="select-trainer" {{#unless hasTrainers}}disabled{{/unless}}>
        <i class="fas fa-arrow-right"></i>
        Suivant
      </button>
    </footer>
  {{/if}}

  {{#if isPrStep}}
    <section class="pfg-grid">
      <div class="pfg-panel">
        <h3>Résumé PR</h3>
        <label>
          Skill utilisé pour les PR
          <select name="prSkillKey">
            {{#each prSkillOptions}}
              <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}} - {{rankLabel}} ({{total}})</option>
            {{/each}}
          </select>
        </label>
        <dl class="pfg-dl">
          <div>
            <dt>Niveau</dt>
            <dd>{{pr.level.value}} <small>{{pr.level.source}}</small></dd>
          </div>
          <div>
            <dt>Power</dt>
            <dd>{{pr.power.value}} <small>{{pr.power.source}}</small></dd>
          </div>
          <div>
            <dt>Skill PR</dt>
            <dd>{{pr.selectedSkill.label}} - {{pr.selectedSkill.rankLabel}} ({{pr.selectedSkill.totalDetail}})</dd>
          </div>
          <div>
            <dt>Jet de fiche</dt>
            <dd>{{pr.selectedSkill.diceFormula}} <small>mod {{pr.selectedSkill.modifierTotal}}</small></dd>
          </div>
          {{#unless pr.usesBestSkill}}
          <div>
            <dt>Meilleur détecté</dt>
            <dd>{{pr.bestSkill.label}} - {{pr.bestSkill.rankLabel}} ({{pr.bestSkill.totalDetail}})</dd>
          </div>
          {{/unless}}
          <div>
            <dt>Calcul</dt>
            <dd>{{pr.detail}}</dd>
          </div>
          <div>
            <dt>PR de base</dt>
            <dd>{{basePRLabel}}</dd>
          </div>
          <div>
            <dt>Bonus PR</dt>
            <dd>{{prBonuses.totalBonusLabel}} <small>dont {{prBonuses.activityTotalLabel}} réservé par activité</small></dd>
          </div>
        </dl>

        {{#if pr.level.missing}}
          <p class="pfg-warning">Niveau non détecté automatiquement. Utilise le champ manuel ci-dessous.</p>
        {{/if}}
        {{#if pr.power.missing}}
          <p class="pfg-warning">Power non détecté automatiquement. Utilise le champ manuel ci-dessous.</p>
        {{/if}}

        <div class="pfg-two-cols">
          <label>
            Niveau utilisé
            <input type="number" name="manualLevel" min="1" step="1" value="{{manualLevel}}" placeholder="{{pr.level.value}}">
          </label>
          <label>
            Power utilisé
            <input type="number" name="manualPower" min="0" step="1" value="{{manualPower}}" placeholder="{{pr.power.value}}">
          </label>
        </div>

        <div class="pfg-two-cols">
          <label>
            Bonus PR
            <input type="number" name="bonusPR" min="0" step="0.25" value="{{prBonuses.globalValue}}" placeholder="0">
          </label>
          <label>
            Bonus PR uniquement Petit Travail
            <input type="number" name="bonusPRWork" min="0" step="0.25" value="{{prBonuses.workValue}}" placeholder="0">
          </label>
        </div>

        <div class="pfg-two-cols">
          <label>
            Bonus PR uniquement Fabrication
            <input type="number" name="bonusPRCrafting" min="0" step="0.25" value="{{prBonuses.craftingValue}}" placeholder="0">
          </label>
          <label>
            Bonus PR uniquement Récolte
            <input type="number" name="bonusPRHarvest" min="0" step="0.25" value="{{prBonuses.harvestValue}}" placeholder="0">
          </label>
        </div>

        <label>
          Bonus PR uniquement Agriculture
          <input type="number" name="bonusPRGardening" min="0" step="0.25" value="{{prBonuses.gardeningValue}}" placeholder="0">
        </label>
      </div>

      <div class="pfg-panel">
        <h3>Semaine</h3>
        {{#if calendar.manual}}
          <label>
            Nom de la semaine
            <input type="text" name="weekName" value="{{calendar.weekName}}" placeholder="Semaine 12">
          </label>
          <label>
            Date RP
            <input type="text" name="rpDate" value="{{calendar.rpDate}}" placeholder="Printemps, jour 4">
          </label>
        {{else}}
          <p>Simple Calendar Reborn détecté.</p>
          <p><strong>{{calendar.calendarLabel}}</strong></p>
        {{/if}}
        <label>
          Événement de la semaine
          <input type="text" name="eventName" value="{{calendar.eventName}}" placeholder="Festival de Flovhavn">
        </label>
        <label>
          Bonus / description
          <textarea name="eventDescription" rows="3">{{calendar.eventDescription}}</textarea>
        </label>

        {{#if weekLocked}}
          <p class="pfg-warning">Cet entretien est déjà finalisé pour cette semaine.</p>
          {{#if canUnlockWeek}}
            <button type="button" data-action="unlock-week">
              <i class="fas fa-lock-open"></i>
              Déverrouiller cette semaine
            </button>
          {{/if}}
        {{/if}}
      </div>
    </section>

    <footer class="pfg-actions">
      <button type="button" data-action="back">
        <i class="fas fa-arrow-left"></i>
        Retour
      </button>
      <button type="button" data-action="to-activity" {{#if weekLocked}}disabled{{/if}}>
        <i class="fas fa-arrow-right"></i>
        Suivant
      </button>
    </footer>
  {{/if}}

  {{#if isActivityStep}}
    <section class="pfg-panel">
      <h3>Choix activité</h3>
      {{#if strictActivityMode}}
        <p class="pfg-note">Mode strict actif: chaque activité confirmée consomme ses PR et reste dans l'historique.</p>
      {{else}}
        <p class="pfg-note">Mode libre actif: les PR restants pourront être dépensés dans plusieurs activités.</p>
      {{/if}}

      <div class="pfg-activity-list">
        {{#each activityOptions}}
          <label class="pfg-activity {{#if disabled}}disabled{{/if}}">
            <input type="radio" name="selectedActivity" value="{{key}}" {{#if selected}}checked{{/if}} {{#if disabled}}disabled{{/if}}>
            <i class="{{icon}}"></i>
            <span>
              <strong>{{title}}</strong>
              <small>{{description}}</small>
            </span>
          </label>
        {{/each}}
      </div>
    </section>

    <footer class="pfg-actions">
      <button type="button" data-action="back">
        <i class="fas fa-arrow-left"></i>
        Retour
      </button>
      <button type="button" data-action="to-work">
        <i class="fas fa-arrow-right"></i>
        Suivant
      </button>
    </footer>
  {{/if}}

  {{#if isCraftingStep}}
    <section class="pfg-panel">
      <h3>Fabrication</h3>

      <button type="button" data-action="open-crafting-journal">
        <i class="fas fa-book-open"></i>
        Journal de fabrication
      </button>

      <div class="pfg-drop-zone {{#if crafting.itemName}}ready{{/if}}" data-drop-target="craftResult">
        <i class="fas fa-box"></i>
        <span>
          <strong>Objet final à fabriquer</strong>
          {{#if crafting.itemName}}
            <small>{{crafting.itemName}}</small>
          {{else}}
            <small>Glisser l'objet final depuis un compendium ou la sidebar Items.</small>
          {{/if}}
        </span>
      </div>

      <div class="pfg-two-cols">
        <label>
          Type
          <select name="craftType" {{#if crafting.locked}}disabled{{/if}}>
            {{#each crafting.typeOptions}}
              <option value="{{key}}" {{#if selected}}selected{{/if}} {{#if disabled}}disabled{{/if}}>{{label}} - {{costLabel}}</option>
            {{/each}}
          </select>
        </label>
        <label>
          Quantité
          <input type="number" name="craftQuantity" min="1" step="1" value="{{crafting.quantity}}" {{#if crafting.locked}}disabled{{/if}}>
        </label>
      </div>

      <div class="pfg-two-cols">
        <label>
          Coût Pokédollars
          <input type="number" name="craftMoneyValue" min="0" step="1" value="{{crafting.moneyValue}}" {{#if crafting.locked}}disabled{{/if}}>
        </label>
        <div class="pfg-inline-options">
          <label class="pfg-check">
            <input type="radio" name="craftMoneyMode" value="total" {{#unless crafting.moneyModeUnit}}checked{{/unless}} {{#if crafting.locked}}disabled{{/if}}>
            Coût total
          </label>
          <label class="pfg-check">
            <input type="radio" name="craftMoneyMode" value="unit" {{#if crafting.moneyModeUnit}}checked{{/if}} {{#if crafting.locked}}disabled{{/if}}>
            Coût unitaire
          </label>
        </div>
      </div>

      <dl class="pfg-dl">
        <div>
          <dt>Coût PR</dt>
          <dd>{{crafting.costLabel}}</dd>
        </div>
        <div>
          <dt>Coût Pokédollars</dt>
          <dd>{{crafting.moneyCostLabel}}</dd>
        </div>
        <div>
          <dt>Restants après</dt>
          <dd>{{crafting.remainingAfterLabel}}</dd>
        </div>
      </dl>

      <div class="pfg-drop-zone" data-drop-target="craftIngredient">
        <i class="fas fa-flask"></i>
        <span>
          <strong>Ingrédients requis</strong>
          <small>Glisser les ingrédients depuis l'inventaire du Trainer. Ils sont réservés et seront retirés seulement à la confirmation.</small>
        </span>
      </div>

      {{#if crafting.hasIngredients}}
        <div class="pfg-ingredient-list">
          {{#each crafting.ingredients}}
            <div class="pfg-ingredient-row {{#unless enough}}missing{{/unless}}">
              <strong>{{name}}</strong>
              <label>
                Qté
                <input type="number" name="craftIngredientQuantity:{{entryId}}" min="1" step="1" value="{{quantity}}" {{#if ../crafting.locked}}disabled{{/if}}>
              </label>
              <span>Disponible: {{availableQuantity}}</span>
              <button type="button" data-action="remove-craft-ingredient" data-entry-id="{{entryId}}" title="Retirer l'ingrédient" {{#if ../crafting.locked}}disabled{{/if}}>
                <i class="fas fa-xmark"></i>
              </button>
            </div>
          {{/each}}
        </div>
      {{else}}
        <p class="pfg-note">Aucun ingrédient réservé.</p>
      {{/if}}

      {{#if crafting.locked}}
        <p class="pfg-success">{{currentActivity.resultStatus}}</p>
      {{else}}
        {{#if crafting.hasRequirementErrors}}
          <ul class="pfg-warning pfg-errors">
            {{#each crafting.requirementErrors}}
              <li>{{this}}</li>
            {{/each}}
          </ul>
        {{/if}}
      {{/if}}
    </section>

    <footer class="pfg-actions">
      <button type="button" data-action="back">
        <i class="fas fa-arrow-left"></i>
        Retour
      </button>
      {{#if crafting.locked}}
        <button type="button" data-action="to-summary">
          <i class="fas fa-list-check"></i>
          Voir résumé
        </button>
      {{else}}
        <button type="button" data-action="confirm-crafting" {{#unless crafting.canCraft}}disabled{{/unless}}>
          <i class="fas fa-hammer"></i>
          Confirmer
        </button>
      {{/if}}
    </footer>
  {{/if}}

  {{#if isHarvestStep}}
    <section class="pfg-panel">
      <h3>Récolte Pokémon</h3>

      <label>
        Récolte
        <select name="harvestKey" {{#if harvest.locked}}disabled{{/if}}>
          {{#each harvest.options}}
            <option value="{{key}}" {{#if selected}}selected{{/if}}>{{category}} - {{label}} ({{costLabel}})</option>
          {{/each}}
        </select>
      </label>

      <label>
        Nombre de récoltes
        <input type="number" name="harvestCount" min="1" max="{{harvest.maxCount}}" step="1" value="{{harvest.count}}" {{#if harvest.locked}}disabled{{/if}}>
      </label>

      <ul class="pfg-harvest-list">
        {{#each harvest.options}}
          <li class="{{#if selected}}selected{{/if}}">
            <strong>{{label}}</strong>
            <small>{{category}} - {{costLabel}} - {{resultTypeLabel}}</small>
          </li>
        {{/each}}
      </ul>

      {{#if harvest.selectedOption}}
        <dl class="pfg-dl">
          <div>
            <dt>Catégorie</dt>
            <dd>{{harvest.selectedOption.category}}</dd>
          </div>
          <div>
            <dt>Coût</dt>
            <dd>{{harvest.costLabel}}</dd>
          </div>
          <div>
            <dt>Coût unitaire</dt>
            <dd>{{harvest.unitCostLabel}}</dd>
          </div>
          <div>
            <dt>Nombre</dt>
            <dd>{{harvest.count}}</dd>
          </div>
          <div>
            <dt>Résultat</dt>
            <dd>{{harvest.selectedOption.resultLabel}} <small>{{harvest.selectedOption.resultTypeLabel}}</small></dd>
          </div>
          {{#if harvest.selectedOption.resultUuid}}
            <div>
              <dt>UUID</dt>
              <dd>{{harvest.selectedOption.resultUuid}}</dd>
            </div>
          {{/if}}
          <div>
            <dt>Restants après</dt>
            <dd>{{harvest.remainingAfterLabel}}</dd>
          </div>
        </dl>
      {{/if}}

      {{#if harvest.requiresPokemon}}
        <div class="pfg-two-cols">
          <label>
            Pokémon détecté
            <select name="harvestPokemonId" {{#if harvest.locked}}disabled{{/if}}>
              <option value="">Nom manuel / non listé</option>
              {{#each harvest.pokemonOptions}}
                <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
              {{/each}}
            </select>
          </label>
          <label class="pfg-check">
            <input type="checkbox" name="harvestOwnsPokemon" {{#if harvest.ownsPokemon}}checked{{/if}} {{#if harvest.locked}}disabled{{/if}}>
            Je confirme posséder le Pokémon requis
          </label>
        </div>

        <div class="pfg-two-cols">
          <label>
            Nom du Pokémon
            <input type="text" name="harvestPokemonName" value="{{harvest.pokemonName}}" placeholder="Nom du Pokémon" {{#if harvest.locked}}disabled{{/if}}>
          </label>
          {{#if harvest.requiresSecondPokemon}}
            <label>
              Deuxième Oricorio
              <input type="text" name="harvestSecondPokemonName" value="{{harvest.secondPokemonName}}" placeholder="Nom du deuxième Oricorio" {{#if harvest.locked}}disabled{{/if}}>
            </label>
          {{/if}}
        </div>
      {{/if}}

      {{#if harvest.requiresPaleontologyConfirmation}}
        <label class="pfg-check">
          <input type="checkbox" name="harvestPaleontologyConfirmed" {{#if harvest.paleontologyConfirmed}}checked{{/if}} {{#if harvest.locked}}disabled{{/if}}>
          Je confirme que le Trainer possède Field of Study: Paleontology
        </label>
      {{/if}}

      {{#if harvest.requiresRareCandyIngredient}}
        <div class="pfg-drop-zone {{#if harvest.rareCandyIngredientConfirmed}}ready{{/if}}" data-drop-target="rareCandyIngredient">
          <i class="fas fa-hand"></i>
          <span>
            <strong>Shuckle's Berry Juice</strong>
            {{#if harvest.rareCandyIngredientName}}
              <small>Déposé: {{harvest.rareCandyIngredientName}}</small>
            {{else}}
              <small>Glisser l'item ici, ou cocher la confirmation manuelle ci-dessous.</small>
            {{/if}}
          </span>
        </div>
        <label class="pfg-check">
          <input type="checkbox" name="harvestRareCandyIngredientConfirmed" {{#if harvest.rareCandyIngredientConfirmed}}checked{{/if}} {{#if harvest.locked}}disabled{{/if}}>
          Je confirme posséder Shuckle's Berry Juice et le retirer manuellement
        </label>
      {{/if}}

      {{#if harvest.detectedOricorioLabel}}
        <p class="pfg-note">Oricorio détectés: {{harvest.detectedOricorioLabel}}</p>
      {{/if}}
      {{#if harvest.requiresPaleontologyConfirmation}}
        <p class="pfg-note">Aucun Pokémon requis pour Fossil Research; seule la confirmation Paleontology est demandée.</p>
      {{/if}}
      {{#if harvest.requiresRareCandyIngredient}}
        <p class="pfg-note">Le module ajoute le Rare Candy si possible, mais ne retire pas automatiquement Shuckle's Berry Juice.</p>
      {{/if}}

      {{#if harvest.locked}}
        <p class="pfg-success">Récolte déjà confirmée: {{harvest.lockedResultStatus}}</p>
      {{else}}
        {{#if harvest.hasRequirementErrors}}
          <ul class="pfg-warning pfg-errors">
            {{#each harvest.requirementErrors}}
              <li>{{this}}</li>
            {{/each}}
          </ul>
        {{/if}}
      {{/if}}
    </section>

    <footer class="pfg-actions">
      <button type="button" data-action="back">
        <i class="fas fa-arrow-left"></i>
        Retour
      </button>
      {{#if harvest.locked}}
        <button type="button" data-action="to-summary">
          <i class="fas fa-list-check"></i>
          Voir résumé
        </button>
      {{else}}
        <button type="button" data-action="roll-harvest" {{#unless harvest.canHarvest}}disabled{{/unless}}>
          <i class="fas fa-leaf"></i>
          Confirmer
        </button>
      {{/if}}
    </footer>
  {{/if}}

  {{#if isWorkStep}}
    <section class="pfg-panel">
      <h3>Petit Travail Hebdomadaire</h3>
      <label>
        Description du travail
        <input type="text" name="workDescription" value="{{work.description}}" placeholder="Déplacement du matériel d'entraînement" {{#if work.locked}}disabled{{/if}}>
      </label>

      <div class="pfg-two-cols">
        <label>
          Skill utilisé
          <select name="workSkillKey" {{#if work.locked}}disabled{{/if}}>
            {{#each work.skillOptions}}
              <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}} - {{rankLabel}} ({{total}})</option>
            {{/each}}
          </select>
        </label>
        <label>
          Nombre de Petits Travaux
          <input type="number" name="workCount" min="1" max="{{work.maxCount}}" step="1" value="{{work.count}}" {{#if work.locked}}disabled{{/if}}>
        </label>
      </div>

      <dl class="pfg-dl">
        <div>
          <dt>Rang détecté</dt>
          <dd>{{work.rankLabel}} ({{work.selectedSkill.totalDetail}})</dd>
        </div>
        <div>
          <dt>Jet de fiche</dt>
          <dd>{{work.selectedSkill.diceFormula}} <small>mod {{work.selectedSkill.modifierTotal}}</small></dd>
        </div>
        <div>
          <dt>Taux</dt>
          <dd>{{work.rate}}₽ par point de d6</dd>
        </div>
        <div>
          <dt>{{#if work.locked}}Nombre lancé{{else}}Maximum possible{{/if}}</dt>
          <dd>{{work.maxCount}}</dd>
        </div>
        <div>
          <dt>Coût total</dt>
          <dd>{{work.costLabel}}</dd>
        </div>
      </dl>

      {{#if work.rateWarning}}
        <p class="pfg-warning">Skill Pathetic ou Untrained: le paiement est 0 sauf taux minimum configuré par le MJ.</p>
      {{/if}}
      {{#if work.locked}}
        <p class="pfg-note">Petit Travail déjà lancé: les PR sont dépensés et les jets sont conservés.</p>
        <ol class="pfg-rolls">
          {{#each work.lockedRolls}}
            <li>{{die}} x {{rate}}₽ = {{gain}}₽</li>
          {{/each}}
        </ol>
        <p><strong>Total gagné:</strong> {{work.lockedTotalGain}}₽</p>
      {{else}}
        {{#unless work.canRoll}}
          <p class="pfg-warning">PR insuffisants pour effectuer un Petit Travail.</p>
        {{/unless}}
      {{/if}}
    </section>

    <footer class="pfg-actions">
      <button type="button" data-action="back">
        <i class="fas fa-arrow-left"></i>
        Retour
      </button>
      {{#if work.locked}}
        <button type="button" data-action="to-summary">
          <i class="fas fa-list-check"></i>
          Voir résumé
        </button>
      {{else}}
        <button type="button" data-action="roll-work" {{#unless work.canRoll}}disabled{{/unless}}>
          <i class="fas fa-dice-d6"></i>
          Lancer
        </button>
      {{/if}}
    </footer>
  {{/if}}

  {{#if isSummaryStep}}
    <section class="pfg-panel">
      <h3>Résumé activité</h3>
      {{#if hasCurrentActivity}}
        {{#if currentActivity.isCrafting}}
          <dl class="pfg-dl">
            <div>
              <dt>Activité</dt>
              <dd>{{currentActivity.title}}</dd>
            </div>
            <div>
              <dt>Objet fabriqué</dt>
              <dd>{{currentActivity.itemName}} × {{currentActivity.quantity}}</dd>
            </div>
            <div>
              <dt>Type</dt>
              <dd>{{currentActivity.craftTypeLabel}}</dd>
            </div>
            <div>
              <dt>Coût PR</dt>
              <dd>{{currentActivity.costLabel}}</dd>
            </div>
            <div>
              <dt>Coût Pokédollars</dt>
              <dd>{{currentActivity.moneyCostLabel}}</dd>
            </div>
          </dl>
          {{#if currentActivity.hasIngredients}}
            <p><strong>Ingrédients consommés:</strong></p>
            <ul class="pfg-rolls">
              {{#each currentActivity.ingredients}}
                <li>{{name}} × {{quantity}}</li>
              {{/each}}
            </ul>
          {{/if}}
          <p class="pfg-success">{{currentActivity.resultStatus}}</p>
        {{else}}
        {{#if currentActivity.isHarvest}}
          <dl class="pfg-dl">
            <div>
              <dt>Activité</dt>
              <dd>{{currentActivity.title}}</dd>
            </div>
            <div>
              <dt>Récolte</dt>
              <dd>{{currentActivity.harvestLabel}} <small>{{currentActivity.harvestCategory}}</small></dd>
            </div>
            <div>
              <dt>Nombre</dt>
              <dd>{{currentActivity.count}}</dd>
            </div>
            <div>
              <dt>{{#if currentActivity.usesPokemon}}Pokémon{{else}}Prérequis{{/if}}</dt>
              <dd>{{currentActivity.pokemonNames}}</dd>
            </div>
            <div>
              <dt>Coût</dt>
              <dd>{{currentActivity.costLabel}}</dd>
            </div>
            <div>
              <dt>Résultat</dt>
              <dd>{{currentActivity.resultLabel}} <small>{{currentActivity.resultTypeLabel}}</small></dd>
            </div>
            {{#if currentActivity.resultUuid}}
              <div>
                <dt>UUID</dt>
                <dd>{{currentActivity.resultUuid}}</dd>
              </div>
            {{/if}}
          </dl>
          {{#if currentActivity.hasResultEntries}}
            <p><strong>Résultats obtenus:</strong></p>
            <ol class="pfg-rolls">
              {{#each currentActivity.resultEntries}}
                <li>{{label}}</li>
              {{/each}}
            </ol>
          {{/if}}
          <p class="pfg-success">{{currentActivity.resultStatus}}</p>
        {{else}}
          <dl class="pfg-dl">
            <div>
              <dt>Activité</dt>
              <dd>{{currentActivity.title}}</dd>
            </div>
            <div>
              <dt>Travail</dt>
              <dd>{{currentActivity.description}}</dd>
            </div>
            <div>
              <dt>Skill</dt>
              <dd>{{currentActivity.skillLabel}} - {{currentActivity.skillRankLabel}}</dd>
            </div>
            <div>
              <dt>Coût</dt>
              <dd>{{currentActivity.costLabel}}</dd>
            </div>
            <div>
              <dt>Total gagné</dt>
              <dd>{{currentActivity.totalGain}}₽</dd>
            </div>
          </dl>

          <ol class="pfg-rolls">
            {{#each currentActivityRolls}}
              <li>{{die}} x {{rate}}₽ = {{gain}}₽</li>
            {{/each}}
          </ol>

          {{#if currentActivity.applied}}
            <p class="pfg-success">Gains appliqués à la fiche.</p>
          {{else}}
            <p class="pfg-note">Par défaut, le module poste un résumé seulement. Les gains ne sont appliqués qu'après confirmation.</p>
          {{/if}}
        {{/if}}
        {{/if}}
      {{else}}
        <p class="pfg-warning">Aucune activité lancée.</p>
      {{/if}}

      {{#if hasActivityHistory}}
        <h3>Historique de l'entretien</h3>
        <ol class="pfg-rolls">
          {{#each activityHistory}}
            <li>
              {{#if isCrafting}}
                <strong>#{{number}} {{title}}</strong> - {{summaryLine}} - {{costLabel}} - {{moneyCostLabel}}
                <small>{{resultStatus}}</small>
              {{else}}
              {{#if isHarvest}}
                <strong>#{{number}} {{title}}</strong> - {{summaryLine}} - {{costLabel}}
                <small>{{resultStatus}}</small>
                {{#if hasResultEntries}}
                  <ol>
                    {{#each resultEntries}}
                      <li>{{label}}</li>
                    {{/each}}
                  </ol>
                {{/if}}
              {{else}}
                <strong>#{{number}} {{title}}</strong> - {{description}} - {{costLabel}} - {{totalGain}}₽
                {{#if applied}}<small>Gains appliqués</small>{{else}}<small>Gains non appliqués</small>{{/if}}
                <ol>
                  {{#each rolls}}
                    <li>{{die}} x {{rate}}₽ = {{gain}}₽</li>
                  {{/each}}
                </ol>
              {{/if}}
              {{/if}}
            </li>
          {{/each}}
        </ol>
      {{/if}}
    </section>

    <footer class="pfg-actions">
      <button type="button" data-action="back">
        <i class="fas fa-arrow-left"></i>
        Retour
      </button>
      <button type="button" data-action="post-activity" {{#unless hasCurrentActivity}}disabled{{/unless}}>
        <i class="fas fa-message"></i>
        Poster résumé
      </button>
      {{#if hasCurrentActivity}}
        {{#unless currentActivity.isHarvest}}
          {{#unless currentActivity.isCrafting}}
            <button type="button" data-action="apply-gains" {{#unless canApplyCurrentActivity}}disabled{{/unless}}>
              <i class="fas fa-coins"></i>
              Appliquer les gains
            </button>
          {{/unless}}
        {{/unless}}
      {{/if}}
      {{#if canStartAnotherActivity}}
        {{#if currentActivity.applied}}
          <button type="button" data-action="new-activity">
            <i class="fas fa-plus"></i>
            Nouvelle activité
          </button>
        {{else}}
          <button type="button" data-action="apply-gains-and-new" {{#unless canApplyCurrentActivity}}disabled{{/unless}}>
            <i class="fas fa-coins"></i>
            Appliquer + nouvelle activité
          </button>
        {{/if}}
      {{/if}}
      {{#if finalized}}
        <button type="button" data-action="new-maintenance">
          <i class="fas fa-rotate-right"></i>
          Nouvel entretien
        </button>
      {{else}}
        <button type="button" data-action="finish" {{#unless hasActivityHistory}}disabled{{/unless}}>
          <i class="fas fa-check"></i>
          Terminer l'entretien
        </button>
      {{/if}}
    </footer>
  {{/if}}
</form>
